  "m00_the_signal": {
    "title": "Planetary Health Check 2025: ocean acidification boundary crossed; 7/9 boundaries exceeded",
    "body": "Stockholm Resilience Centre highlights that the 2025 Planetary Health Check finds seven of nine planetary boundaries exceeded, with ocean acidification breached for the first time. This is a structural regime signal: the buffering capacity of the Earth system is degrading across multiple domains simultaneously, raising the probability that regional shocks (heat, water stress, food) cascade into governance and security stress faster than institutions can adapt.",
    "filter_tag": "F1"
  },
  "m01_executive_insight": {
    "items": [
      {
        "headline": "Boundary stack is tightening the strategic operating space",
        "summary": "The transition from six to seven breached boundaries (via ocean acidification) is a durability signal: mitigation in one domain is increasingly offset by deterioration in others, compressing policy timelines and increasing tail-risk coupling between climate, food systems, and maritime security.",
        "tier": "Tier 1",
        "filter_tag": "F1",
        "source_url": "https://www.stockholmresilience.org/research/planetary-boundaries.html"
      },
      {
        "headline": "IPCC AR7 cycle governance sets the next decision window",
        "summary": "IPCC-64 (24–27 March 2026) advanced AR7 work programme and upcoming deliverables (cities report in 2027; CDR/CCUS methodology in 2027). This shapes the global evidence base and, indirectly, regulatory baselines that drive capital allocation and litigation risk over 2026–2029.",
        "tier": "Tier 1",
        "filter_tag": "F1",
        "source_url": "https://www.ipcc.ch/2026/03/23/press-release-ipcc64-opening/"
      }
    ]
  },
